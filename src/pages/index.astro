---
import { Code } from "astro-expressive-code/components";
import { Icon } from "astro-icon/components";
import MainCard from "@/components/MainCard.astro";
import FeatureCard from "@/components/mdx/FeatureCard.astro";
import GitHubStats from "@/components/mdx/GitHubStats.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Home">
  <MainCard
    title="INK's Blog"
    description="Meow"
    textOverlay="HOME"
    overlayImage="/bg.jpeg"
    infoIcon="lucide:info"
  >
    <div class="space-y-8">
      <!-- Hero Section -->
      <section class="py-6">
        <div class="flex flex-col items-center text-center">
          <h1
            class="text-4xl font-bold mb-4 bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent leading-loose"
          >
            🌟 INK's Blog
          </h1>
          <p class="text-xl text-base-content/80 max-w-3xl mb-8">
            共享 · 便捷 · 实用
          </p>
          <!-- <div class="flex flex-wrap gap-4 justify-center">
            <a href="/blog" class="btn btn-primary gap-2 btn-shine-effect">
              <Icon name="lucide:book-open" class="w-5 h-5" />
              <span>Explore Blog</span>
            </a>
            <a href="https://github.com/EveSunMaple/Frosti" target="_blank" class="btn btn-outline gap-2">
              <Icon name="lucide:github" class="w-5 h-5" />
              <span>Star on GitHub</span>
            </a>
          </div> -->
        </div>
      </section>

      <!-- Features Section -->
      <section class="py-6">
        <h2 class="text-2xl font-bold mb-6 flex items-center gap-2">
          <Icon name="lucide:sparkles" class="w-6 h-6 text-primary" />
          <span>关于 ink</span>
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <FeatureCard
            title="Hypixel SkyBlock"
            description="平时喜欢玩 Hypixel SkyBlock。"
            icon="lucide:swords"
            color="oklch(0.7 0.2 30)"
          />

          <FeatureCard
            title="编程"
            description="编程是我最投入的爱好之一，喜欢折腾各种项目，把脑子里的想法一点点写成真正能跑起来的东西。"
            icon="lucide:code-2"
            color="oklch(0.65 0.2 280)"
          />

          <FeatureCard
            title="视频剪辑"
            description="喜欢剪辑视频，享受把素材拼接、配乐和做节奏处理，做出更有表达力内容的感觉。"
            icon="lucide:clapperboard"
            color="oklch(0.6 0.2 160)"
          />

          <FeatureCard
            title="B站 UP主"
            description="在 B 站发视频，分享自己的作品、想法和日常折腾出来的内容，认真做一名属于自己的 UP 主。"
            icon="lucide:video"
            color="oklch(0.6 0.2 200)"
          />
        </div>
      </section>

